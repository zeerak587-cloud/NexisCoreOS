#!/bin/sh
set -eu

export PATH=/bin:/sbin

mount -t proc proc /proc
mount -t sysfs sys /sys
mount -t devtmpfs dev /dev || true
mount -t tmpfs tmpfs /run

if [ ! -c /dev/console ]; then
  mknod -m 600 /dev/console c 5 1
fi
if [ ! -c /dev/null ]; then
  mknod -m 666 /dev/null c 1 3
fi

echo
echo "=========================================="
echo "      NexisCoreOS booted successfully      "
echo "=========================================="
echo "Serving repository contents on http://127.0.0.1:8080"
echo

/bin/httpd -f -p 8080 -h /srv/nexis &
HTTPD_PID=$!

/bin/sh <<'SHELL'
cat <<'TXT'
NexisCoreOS emergency shell

Useful commands:
  ls /srv/nexis      # view repository files inside the OS image
  ps                 # verify HTTP server process
  poweroff -f        # shutdown the VM
TXT
SHELL

kill "$HTTPD_PID" 2>/dev/null || true
poweroff -f
